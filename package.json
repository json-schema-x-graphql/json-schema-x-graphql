{
  "name": "json-schema-x-graphql",
  "version": "0.1.0",
  "description": "Bidirectional, lossless conversion between JSON Schema and GraphQL SDL with Apollo Federation support",
  "main": "converters/rust/pkg/json_schema_graphql_converter.js",
  "module": "converters/rust/pkg/json_schema_graphql_converter.js",
  "types": "converters/rust/pkg/json_schema_graphql_converter.d.ts",
  "files": [
    "converters/rust/pkg",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "converters/node"
  ],
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "npm run build:wasm",
    "build:wasm": "cd converters/rust && wasm-pack build --target web --out-dir ../../frontend/schema-authoring/src/wasm --release",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "prepublishOnly": "npm run build",
    "docs": "typedoc src/index.ts",
    "converters:node:install": "npm install --prefix converters/node",
    "converters:node:build": "npm run build --prefix converters/node",
    "converters:node:test": "npm test --prefix converters/node",
    "converters:rust:build": "cd converters/rust && cargo build --release",
    "converters:rust:test": "cd converters/rust && cargo test",
    "converters:test": "npm run converters:node:test && npm run converters:rust:test",
    "converters:compare": "node scripts/test-both-converters.js",
    "test:parity": "jest converters/node/src/parity.test.ts",
    "skip-report:run": "node scripts/skip-report.js --input . --output reports/skip-report.json",
    "skip-report:summary": "node scripts/summarize-skip-report.js --input reports/skip-report.json --output reports/skip-report-summary.txt",
    "skip-report:all": "npm run skip-report:run && npm run skip-report:summary"
  },
  "keywords": [
    "graphql",
    "json-schema",
    "apollo-federation",
    "wasm",
    "schema-conversion",
    "bidirectional",
    "validation",
    "type-system"
  ],
  "author": "JJediny and Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JJediny/json-schema-x-graphql.git"
  },
  "bugs": {
    "url": "https://github.com/JJediny/json-schema-x-graphql/issues"
  },
  "homepage": "https://github.com/JJediny/json-schema-x-graphql#readme",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@theguild/federation-composition": "^0.21.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "graphql": "^16.7.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "rollup": "^4.9.4",
    "ts-jest": "^29.1.1",
    "typedoc": "^0.25.6",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "graphql": "^16.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
