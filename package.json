{
  "name": "json-schema-x-graphql",
  "version": "2.0.0",
  "description": "Bidirectional, lossless conversion between JSON Schema and GraphQL SDL with Apollo Federation support",
  "keywords": [
    "apollo-federation",
    "bidirectional",
    "graphql",
    "json-schema",
    "schema-conversion",
    "type-system",
    "validation",
    "wasm"
  ],
  "homepage": "https://github.com/json-schema-x-graphql/json-schema-x-graphql#readme",
  "bugs": {
    "url": "https://github.com/json-schema-x-graphql/json-schema-x-graphql/issues"
  },
  "license": "MIT",
  "author": "json-schema-x-graphql contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/json-schema-x-graphql/json-schema-x-graphql.git"
  },
  "files": [
    "converters/rust/pkg",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "main": "converters/rust/pkg/json_schema_graphql_converter.js",
  "module": "converters/rust/pkg/json_schema_graphql_converter.js",
  "types": "converters/rust/pkg/json_schema_graphql_converter.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:wasm",
    "build:wasm": "cd converters/rust && wasm-pack build --target web --out-dir ../../frontend/subgraph-composer/src/salvaged/wasm --release",
    "test": "jest --runInBand --testPathIgnorePatterns converters/node/src/parity.test.ts",
    "test:watch": "jest --watch",
    "lint": "oxlint check . --ignore-path=.prettierignore && eslint \"converters/node/src/**/*.ts\" \"converters/cli/src/**/*.ts\" \"scripts/**/*.js\" \"scripts/**/*.ts\"",
    "lint:fix": "oxlint fix . --ignore-path=.prettierignore && eslint \"converters/node/src/**/*.ts\" \"converters/cli/src/**/*.ts\" \"scripts/**/*.js\" \"scripts/**/*.ts\" --fix",
    "lint:eslint": "eslint \"converters/node/src/**/*.ts\" \"converters/cli/src/**/*.ts\" \"scripts/**/*.js\" \"scripts/**/*.ts\"",
    "lint:eslint:fix": "eslint \"converters/node/src/**/*.ts\" \"converters/cli/src/**/*.ts\" \"scripts/**/*.js\" \"scripts/**/*.ts\" --fix",
    "lint:oxlint": "oxlint check . --ignore-path=.prettierignore",
    "lint:oxlint:fix": "oxlint fix . --ignore-path=.prettierignore",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:fix": "npm run format",
    "format:prettier": "prettier --check .",
    "format:prettier:fix": "prettier --write .",
    "format:oxfmt": "oxfmt check .",
    "format:oxfmt:fix": "oxfmt check . --write",
    "docs": "typedoc src/index.ts",
    "converters:node:install": "npm install --prefix converters/node",
    "converters:node:build": "npm run build --prefix converters/node",
    "converters:node:test": "npm test --prefix converters/node",
    "converters:rust:build": "cd converters/rust && cargo build --release",
    "converters:rust:test": "cd converters/rust && cargo test",
    "converters:test": "npm run converters:node:test && npm run converters:rust:test",
    "converters:compare": "node scripts/test-both-converters.js",
    "test:parity": "jest converters/node/src/parity.test.ts --runInBand",
    "test:roundtrip:ci": "node scripts/roundtrip-ci.mjs",
    "skip-report:run": "node scripts/skip-report.js --input . --output reports/skip-report.json",
    "skip-report:summary": "node scripts/summarize-skip-report.js --input reports/skip-report.json --output reports/skip-report-summary.txt",
    "skip-report:all": "npm run skip-report:run && npm run skip-report:summary",
    "validate-schemas": "pnpm --filter @json-schema-x-graphql/cli run validate:schemas",
    "validate-graphql": "pnpm --filter @json-schema-x-graphql/cli run validate:graphql",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ajv": "8.17.1",
    "graphql": "^16.14.0"
  },
  "devDependencies": {
    "@apollo/subgraph": "^2.14.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@theguild/federation-composition": "^0.22.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "axios": "1.16.1",
    "dompurify": "^3.4.0",
    "eslint": "^9.20.0",
    "glob": "^7.2.3",
    "graphql": "^16.14.0",
    "graphql-language-service": "^5.5.0",
    "jest": "^29.7.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "prettier": "^3.8.3",
    "rimraf": "^3.0.2",
    "rollup": "^4.60.3",
    "tar": "^7.5.11",
    "ts-jest": "^29.4.9",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "wasm-pack": "^0.14.0",
    "webpack": "5.106.0"
  },
  "peerDependencies": {
    "graphql": "^16.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.5.2"
}
