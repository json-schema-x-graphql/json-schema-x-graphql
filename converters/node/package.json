{
  "name": "@json-schema-x-graphql/core",
  "version": "2.0.0",
  "description": "Bidirectional JSON Schema ↔ GraphQL SDL converter with x-graphql extensions and full Apollo Federation v2 support",
  "keywords": [
    "apollo",
    "apollo-federation",
    "converter",
    "federation",
    "graphql",
    "graphql-federation",
    "json-schema",
    "schema-conversion",
    "sdl",
    "typescript",
    "validation",
    "x-graphql"
  ],
  "homepage": "https://github.com/json-schema-x-graphql/json-schema-x-graphql#readme",
  "bugs": {
    "url": "https://github.com/json-schema-x-graphql/json-schema-x-graphql/issues"
  },
  "license": "MIT",
  "author": "json-schema-x-graphql Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/json-schema-x-graphql/json-schema-x-graphql.git",
    "directory": "converters/node"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/converter.js",
  "types": "dist/converter.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev:api": "tsx src/api-server.ts",
    "start:api": "node dist/api-server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageProvider=v8",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm run test",
    "test:integration": "tsx ../../scripts/integration/test-conversions.ts",
    "test:integration:ci": "tsx ../../scripts/integration/test-conversions.ts --fail-on-error --output=integration-report.json",
    "benchmark": "tsx ../../scripts/benchmarks/run-benchmarks.ts",
    "benchmark:quick": "tsx ../../scripts/benchmarks/run-benchmarks.ts --iterations=10",
    "benchmark:full": "tsx ../../scripts/benchmarks/run-benchmarks.ts --iterations=1000 --output=benchmark-report.json",
    "benchmark:compare": "tsx ../../scripts/benchmarks/run-benchmarks.ts --compare=baseline-benchmark.json --output=current-benchmark.json",
    "ci:validate": "pnpm --filter @json-schema-x-graphql/cli run validate:all -- --fail-on-error --output=validation-report.json",
    "ci:test": "npm run test:integration:ci && npm test",
    "ci:benchmark": "npm run benchmark:full",
    "precommit": "npm run lint"
  },
  "dependencies": {
    "@graphql-codegen/core": "^6.1.0",
    "@graphql-codegen/plugin-helpers": "^7.0.1",
    "@opentelemetry/api": "^1.9.0",
    "@standard-schema/spec": "^1.1.0",
    "graphql": "^17.0.1",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/typescript": "^6.1.0",
    "@opentelemetry/sdk-trace-base": "^1.26.0",
    "@opentelemetry/sdk-trace-node": "^1.26.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.40",
    "eslint": "9.20.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  },
  "optionalDependencies": {
    "@opentelemetry/sdk-trace-base": "^1.26.0",
    "@opentelemetry/sdk-trace-node": "^1.26.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.13.1"
}
