{
  "name": "@json-schema-x-graphql/node-converter",
  "version": "0.1.0",
  "description": "Bidirectional, lossless converter between JSON Schema and GraphQL SDL with x-graphql-* extensions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:wasm": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.wasm.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "docs": "typedoc src/index.ts"
  },
  "keywords": [
    "json-schema",
    "graphql",
    "converter",
    "apollo-federation",
    "schema",
    "sdl",
    "x-graphql",
    "bidirectional",
    "lossless"
  ],
  "author": "JSON Schema x GraphQL Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/json-schema-x-graphql/node-converter.git"
  },
  "bugs": {
    "url": "https://github.com/json-schema-x-graphql/json-schema-x-graphql/issues"
  },
  "homepage": "https://github.com/json-schema-x-graphql/json-schema-x-graphql#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "graphql": "^16.8.1",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "@graphql-tools/schema": "^10.0.2",
    "@graphql-tools/utils": "^10.0.11",
    "@graphql-tools/json-schema-loader": "^10.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typedoc": "^0.25.6",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "../../rust/pkg/json_schema_graphql_converter.js": "<rootDir>/__mocks__/rust-module.cjs",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.[tj]sx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/*.test.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "arrowParens": "always"
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:prettier/recommended"
    ],
    "rules": {
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/explicit-function-return-type": "off",
      "@typescript-eslint/explicit-module-boundary-types": "off"
    }
  }
}
