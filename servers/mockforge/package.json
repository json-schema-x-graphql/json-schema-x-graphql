{
  "name": "@example-forest/mockforge-poc",
  "version": "1.0.0",
  "description": "Federation-aware mock GraphQL services with faker.js and GraphQL Mesh",
  "type": "module",
  "scripts": {
    "root:start": "bash ./run-mockforge.sh 3000",
    "root:docker": "docker compose up mockforge",
    "root:docker:build": "docker compose up --build mockforge",
    "root:full": "docker compose up",
    "root:services": "pnpm run services:start",
    "root:services:docker": "docker compose up",
    "root:mesh": "pnpm run mesh:dev",
    "root:router": "pnpm run router:dev",
    "services:start": "node scripts/start-services.mjs",
    "services:stop": "pkill -f mock-server || true",
    "services:restart": "npm run services:stop && sleep 2 && npm run services:start",
    "services:watch": "nodemon --watch ../../../generated-schemas --exec 'npm run services:restart'",
    "service:fpds": "PORT=4001 SYSTEM=fpds node mock-server.js",
    "service:usaspending": "PORT=4002 SYSTEM=usaspending node mock-server.js",
    "service:assist": "PORT=4003 SYSTEM=assist node mock-server.js",
    "service:easi": "PORT=4004 SYSTEM=easi node mock-server.js",
    "service:calm": "PORT=4005 SYSTEM=calm node mock-server.js",
    "service:example": "PORT=4006 SYSTEM=example node mock-server.js",
    "gateway": "PORT=4000 node gateway-server.js",
    "gateway:docker": "PORT=4000 DOCKER=1 node gateway-server.js",
    "mesh:dev": "mesh dev",
    "mesh:start": "mesh start",
    "mesh:validate": "mesh validate",
    "mesh:build": "mesh build",
    "router:dev": "rover dev --supergraph-config router-config.yaml",
    "router:start": "./router --config router.yaml --supergraph ../../../generated-schemas/example.supergraph.graphql",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose restart",
    "test": "node --test test/**/*.test.js",
    "test:integration": "node --test test/integration/**/*.test.js"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "@graphql-hive/gateway": "^1.16.5",
    "@graphql-mesh/cli": "^0.100.34",
    "@graphql-mesh/graphql": "^0.96.6",
    "@graphql-mesh/runtime": "^0.100.8",
    "@graphql-mesh/store": "^0.95.8",
    "@graphql-mesh/types": "^0.96.6",
    "@graphql-tools/delegate": "^9.0.35",
    "@graphql-tools/executor-http": "^1.3.3",
    "@graphql-tools/graphql-file-loader": "^8.1.11",
    "@graphql-tools/load": "^8.1.8",
    "@graphql-tools/merge": "^9.1.7",
    "@graphql-tools/mock": "^9.1.5",
    "@graphql-tools/schema": "^10.0.31",
    "@graphql-tools/stitch": "^9.4.29",
    "@graphql-tools/utils": "^10.11.0",
    "@graphql-tools/wrap": "^10.1.4",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.6.0",
    "graphql": "^16.13.1",
    "graphql-yoga": "^5.18.0"
  },
  "devDependencies": {
    "@apollo/rover": "^0.21.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "graphql",
    "federation",
    "mock",
    "faker",
    "mesh",
    "apollo"
  ],
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.4.0",
      "minimatch": ">=10.2.3",
      "@isaacs/brace-expansion": ">=5.0.1",
      "tar": ">=7.5.8",
      "ws": ">=8.17.1",
      "axios": ">=1.7.4",
      "immutable": ">=4.0.0"
    }
  }
}
