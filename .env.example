# Shared Environment Configuration for Frontend Demos
# Copy to .env or .env.local in frontend/demos/* directories

# ============================================================================
# Converter Configuration
# ============================================================================

# Converter execution mode: "wasm" (local) or "node" (fallback via server)
VITE_CONVERTER_MODE=wasm

# Node.js converter server endpoint (if using node mode or as fallback)
VITE_CONVERTER_SERVER_URL=http://localhost:3000/api/convert

# Converter options defaults
VITE_CONVERTER_ID_STRATEGY=auto
VITE_CONVERTER_FAIL_ON_WARNING=false
VITE_CONVERTER_NAMING_CONVENTION=PascalCase
VITE_CONVERTER_FEDERATION_VERSION=2

# ============================================================================
# WebSocket / Collaboration Configuration
# ============================================================================

# For Yjs demo: WebSocket server for real-time collaboration
VITE_YSERVER_URL=ws://localhost:1234

# For Loro demo: Optional sync server (if implementing peer sync)
VITE_LORO_SYNC_SERVER_URL=ws://localhost:8080

# ============================================================================
# UI & Theming
# ============================================================================

# Theme preference: "dark" or "light"
VITE_THEME=dark

# Enable experimental features
VITE_ENABLE_EXPERIMENTAL=false

# ============================================================================
# Analytics & Debugging
# ============================================================================

# Lightweight telemetry (optional)
VITE_ENABLE_TELEMETRY=false

# Enable console logging for converter operations
VITE_DEBUG_CONVERTER=true
