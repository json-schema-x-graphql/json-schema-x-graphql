{
  "name": "@json-schema-x-graphql/schema-authoring",
  "version": "1.0.0",
  "private": true,
  "description": "JSON Schema authoring UI with live GraphQL SDL conversion, validation, and AI-accessible APIs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd ../../converters/node && pnpm run dev:api",
    "dev:full": "concurrently \"pnpm run dev:api\" \"pnpm run dev\" --names \"API,VITE\" --prefix-colors \"blue,green\"",
    "debug:browser": "tsx debug-browser.ts",
    "debug:install": "pnpm add -D playwright @playwright/test && pnpm exec playwright install chromium",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test tests --project=chromium",
    "build:wasm": "sh ../../scripts/build-wasm.sh",
    "postinstall": "npm run build:wasm || echo 'WASM build skipped - will use Node converter only'"
  },
  "dependencies": {
    "@graphql-tools/utils": "^10.11.0",
    "@monaco-editor/react": "^4.7.0",
    "ajv": "8.18.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "clsx": "^2.1.1",
    "graphql": "^16.13.2",
    "immer": "^10.2.0",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.52.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^2.6.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "@json-schema-x-graphql/core": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
