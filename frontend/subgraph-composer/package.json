{
  "name": "subgraph-composer",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight utility to compose multiple JSON Schemas into a unified GraphQL supergraph",
  "keywords": [
    "composer",
    "federation",
    "graphql",
    "json-schema",
    "subgraph",
    "x-graphql"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5175",
    "kill-dev": "lsof -ti:5176 | xargs kill -9 2>/dev/null || true",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest src/__tests__/e2e.test.js",
    "clean": "rimraf dist .vite node_modules coverage",
    "format": "prettier --write \"src/**/*\" \"index.html\"",
    "lint": "eslint src/**/*.{jsx,js}",
    "analyze": "du -sh dist/"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.36",
    "@graphql-tools/utils": "^11.2.0",
    "@internal/ui": "workspace:*",
    "@json-schema-x-graphql/core": "file:../../converters/node",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-zone": "^2.9.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-web": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@visual-json/core": "workspace:*",
    "@visual-json/react": "workspace:*",
    "@xyflow/react": "^12.11.2",
    "graphql": "^17.0.2",
    "graphql-editor": "^7.3.1",
    "graphql-voyager": "^2.1.0",
    "mermaid": "11.16.0",
    "react": "^18.3.1",
    "react-dom": "^19.2.7",
    "vanilla-jsoneditor": "^3.12.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-jest": "^30.4.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "vite": "^6.4.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
