{
  "name": "subgraph-composer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lightweight utility to compose multiple JSON Schemas into a unified GraphQL supergraph",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5175",
    "kill-dev": "lsof -ti:5175 | xargs kill -9 2>/dev/null || true",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest src/__tests__/e2e.test.js",
    "clean": "rimraf dist .vite node_modules coverage",
    "format": "prettier --write \"src/**/*\" \"index.html\"",
    "lint": "eslint src/**/*.{jsx,js}",
    "analyze": "du -sh dist/"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.32",
    "@graphql-tools/utils": "^11.0.1",
    "@json-schema-x-graphql/core": "file:../../converters/node",
    "graphql": "^16.13.2",
    "graphql-editor": "^7.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-split-pane": "^3.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-jest": "^30.3.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "vite": "^8.0.8"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "graphql",
    "json-schema",
    "composer",
    "federation",
    "subgraph",
    "x-graphql"
  ]
}
