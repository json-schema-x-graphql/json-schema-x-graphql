{
  "name": "json-viewer",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "generate:docs:index": "node scripts/generate-docs-index.mjs",
    "prebuild": "pnpm run generate:docs:index",
    "dev": "next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "build:graphql-editor": "(cd tools/graphql-editor && pnpm install && pnpm run build)",
    "clean:graphql-editor": "rimraf public/graphql-editor",
    "postbuild": "next-sitemap --config next-sitemap.config.js",
    "start": "next start",
    "check-links": "linkinator http://localhost:3000 --internal --allow-local --concurrency 10",
    "check-links:static": "bash -lc \"npx serve out -s -l 5000 & PID=$!; sleep 1; linkinator http://localhost:5000 --internal --allow-local --concurrency 10; kill $PID || true\"",
    "check-links:build": "pnpm run build && pnpm run check-links:static",
    "postinstall": "mkdir -p node_modules/monaco-editor/esm/vs/base/browser/ui/actionbar && touch node_modules/monaco-editor/esm/vs/base/browser/ui/actionbar/actionbar.css || true && mkdir -p node_modules/monaco-editor/esm/vs/editor && touch node_modules/monaco-editor/esm/vs/editor/editor.main.css || true && mkdir -p node_modules/graphql-editor/dist && touch node_modules/graphql-editor/dist/style.css || true",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.mjs",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.mjs --coverage --coverageDirectory='coverage' --coverageReporters=text --coverageReporters=json-summary --coverageReporters=html --coverageReporters=lcov",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.mjs --watch",
    "security:check": "bash scripts/verify-react2shell-cve.sh",
    "security:audit": "pnpm audit",
    "lint": "tsc --project tsconfig.json && eslint \"src/**/*.{js,ts,tsx,mjs}\" && prettier --check \"src/**/*.{js,ts,tsx,mjs,json,md}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,ts,tsx,mjs}\" && prettier --write \"src/**/*.{js,ts,tsx,mjs,json,md}\"",
    "eslint": "eslint \"src/**/*.{js,ts,tsx,mjs}\"",
    "eslint:fix": "eslint --fix \"src/**/*.{js,ts,tsx,mjs}\"",
    "lint:graphql": "eslint \"src/**/*.{graphql,gql}\" --ext .graphql,.gql || true",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "validate:schema": "node scripts/validate-schema.mjs",
    "validate:graphql": "node scripts/validate-graphql-vs-jsonschema.mjs",
    "validate:sync": "node scripts/validate-schema-sync.mjs",
    "validate:sync:strict": "node scripts/validate-schema-sync.mjs --strict --config scripts/schema-sync.config.json",
    "validate:all": "pnpm run validate:schema && pnpm run validate:graphql && pnpm run validate:sync",
    "validate:all:strict": "pnpm run validate:all && pnpm run validate:sync:strict",
    "generate:subgraph:legacy_procurement": "node scripts/generate-subgraph-sdl.mjs src/data/legacy_procurement.schema.json",
    "generate:subgraph:intake_process": "node scripts/generate-subgraph-sdl.mjs src/data/intake_process.schema.json",
    "generate:subgraph:logistics_mgmt": "node scripts/generate-subgraph-sdl.mjs src/data/logistics_mgmt.schema.json",
    "generate:subgraph:contract_data": "node scripts/generate-subgraph-sdl.mjs src/data/contract_data.schema.json",
    "generate:subgraph:public_spending": "node scripts/generate-subgraph-sdl.mjs src/data/public_spending.schema.json",
    "generate:subgraphs": "pnpm run generate:subgraph:legacy_procurement && pnpm run generate:subgraph:intake_process && pnpm run generate:subgraph:logistics_mgmt && pnpm run generate:subgraph:contract_data && pnpm run generate:subgraph:public_spending",
    "generate:supergraph": "node scripts/generate-supergraph.mjs",
    "generate:schemas": "pnpm run generate:subgraphs && pnpm run generate:supergraph",
    "generate:schema:interop": "node scripts/generate-schema-interop.mjs",
    "generate:schema:introspection": "node scripts/generate-schema_unification-introspection.mjs",
    "generate:schema:graphql": "node scripts/generate-graphql-json-schema.mjs",
    "generate:examples": "node scripts/generate-examples.mjs",
    "generate:examples:graphql": "node scripts/generate-from-subgraphs.mjs --seed=1234",
    "generate:mapping": "node scripts/generate-mapping-from-sdl.mjs",
    "generate:mapping:ci": "node scripts/generate-mapping-from-sdl.mjs --no-public",
    "generate:canonical-subgraphs": "node scripts/generate-canonical-subgraphs.mjs",
    "compose:validate:theguild": "node -e \"console.log('To run validation/benchmarking with @theguild/federation-composition, install the package and run the CLI against generated-schemas/subgraphs or generated-schemas/canonical-subgraphs. Example (once installed): npx @theguild/federation-composition build generated-schemas/subgraphs/*.graphql')\"",
    "analyze": "ANALYZE=true npm run build",
    "federalist": "npm install && NODE_OPTIONS='--max-old-space-size=4096' npm run build && npx serve@latest out",
    "generate:composition-artifacts": "node scripts/generate-composition-artifacts.mjs",
    "generate:unified_model": "node scripts/generate-unified_model-views.mjs",
    "ci:compose": "pnpm run generate:schemas && pnpm run validate:all",
    "ci:compose:legacy": "pnpm run generate:canonical-subgraphs && pnpm run generate:composition-artifacts",
    "mock:start": "bash dev/pocs/mockforge/run-mockforge.sh 3000",
    "mock:serve": "pnpm run generate:supergraph && pnpm run mock:start",
    "mock:docker": "cd dev/pocs/mockforge && docker compose up mockforge",
    "mock:docker:build": "cd dev/pocs/mockforge && docker compose up --build mockforge",
    "mock:services": "cd dev/pocs/mockforge && pnpm install && pnpm run services:start",
    "mock:services:docker": "cd dev/pocs/mockforge && docker compose up",
    "mock:mesh": "cd dev/pocs/mockforge && pnpm install && pnpm run mesh:dev",
    "mock:router": "cd dev/pocs/mockforge && pnpm install && pnpm run router:dev",
    "mock:full": "cd dev/pocs/mockforge && docker compose up",
    "db:restore": "bash -lc 'cd dev/hasura-ddn && ./scripts/restore-unified_model-dump.sh --dump-dir ${DUMP_DIR:-./dumps/pruned_data_store_api_dump} --mode host --jobs ${JOBS:-8}'",
    "db:import": "bash -lc 'cd dev/hasura-ddn && ./scripts/import-schemas.sh --start'",
    "ddn:build": "bash -lc 'cd dev/hasura-ddn && ddn supergraph build local'",
    "ddn:start": "bash -lc 'cd dev/hasura-ddn && ddn run docker-start'",
    "ddn:stop": "bash -lc 'cd dev/hasura-ddn && ddn run docker-stop'",
    "ddn:down": "bash -lc 'cd dev/hasura-ddn && ddn run docker-down'",
    "ddn:console": "bash -lc 'cd dev/hasura-ddn && ddn run console'",
    "ddn:sync": "bash -lc 'cd dev/hasura-ddn && ddn run sync-all'",
    "ddn:connector:init": "bash -lc 'cd dev/hasura-ddn && ddn run connector-init'",
    "ddn:connector:introspect": "bash -lc 'cd dev/hasura-ddn && ddn run connector-introspect'",
    "ddn:model:add": "bash -lc 'cd dev/hasura-ddn && ddn run model-add-all'",
    "ddn:relationship:add": "bash -lc 'cd dev/hasura-ddn && ddn run relationship-add-all'",
    "mv:refresh": "bash -lc 'cd dev/hasura-ddn && ddn run mv-refresh'",
    "mv:refresher:start": "bash -lc 'cd dev/hasura-ddn && ddn run mv-refresher-start'",
    "mv:refresher:stop": "bash -lc 'cd dev/hasura-ddn && ddn run mv-refresher-stop'",
    "mv:refresher:logs": "bash -lc 'cd dev/hasura-ddn && ddn run mv-refresher-logs'"
  },
  "dependencies": {
    "@graphql-mesh/cli": "^0.100.16",
    "@graphql-tools/utils": "10.10.1",
    "@mantine/code-highlight": "^7.17.8",
    "@mantine/core": "^7.17.8",
    "@mantine/dropzone": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@monaco-editor/react": "^4.7.0",
    "@omnigraph/json-schema": "^0.109.16",
    "@tanstack/react-query": "^5.90.2",
    "allotment": "^1.20.4",
    "axios": "^1.12.2",
    "dayjs": "^1.11.18",
    "fast-xml-parser": "^5.3.0",
    "gofmt.js": "^0.0.2",
    "graphql": "^16.11.0",
    "graphql-editor": "^7.3.1",
    "graphql-voyager": "^2.1.0",
    "graphql-yoga": "^5.16.1",
    "gray-matter": "^4.0.3",
    "html-to-image": "1.11.11",
    "jq-web": "^0.5.1",
    "js-cookie": "^3.0.5",
    "js-yaml": "^4.1.1",
    "json-2-csv": "^5.5.9",
    "json-schema-faker": "^0.5.9",
    "json_typegen_wasm": "^0.7.0",
    "jsonc-parser": "^3.3.1",
    "jsonpath-plus": "^10.3.0",
    "jsonwebtoken": "^9.0.2",
    "lodash.debounce": "^4.0.8",
    "mermaid": "^11.12.1",
    "next": "14.2.32",
    "next-seo": "^6.8.0",
    "next-sitemap": "^4.2.3",
    "nextjs-google-analytics": "^2.3.7",
    "react": "^18.3.1",
    "react-compare-slider": "^3.1.0",
    "react-countup": "^6.5.3",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-json-tree": "^0.18.0",
    "react-linkify-it": "^1.0.8",
    "react-markdown": "^10.1.0",
    "react-text-transition": "^3.1.0",
    "react-zoomable-ui": "^0.11.0",
    "reaflow": "5.4.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "styled-components": "^6.1.19",
    "toml": "^3.0.0",
    "use-long-press": "^3.3.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.37.0",
    "@faker-js/faker": "^8.0.2",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@graphql-inspector/cli": "^5.0.8",
    "@graphql-tools/merge": "^9.0.25",
    "@graphql-tools/mock": "^9.0.25",
    "@graphql-tools/schema": "^10.0.25",
    "@next/bundle-analyzer": "^14.2.33",
    "@slidev/cli": "^52.11.0",
    "@slidev/theme-default": "^0.25.0",
    "@theguild/federation-composition": "^0.20.2",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/jest": "^29.5.12",
    "@types/js-cookie": "^3.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.19",
    "@types/react": "18.2.51",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "ajv": "^8.17.1",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "core-types-graphql": "^3.0.0",
    "core-types-json-schema": "^2.2.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "14.2.28",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unused-imports": "^3.2.0",
    "glob": "^11.1.0",
    "jest": "^29.7.0",
    "json-schema-to-graphql-types": "^1.0.0",
    "linkinator": "^7.5.0",
    "null-loader": "^4.0.1",
    "playwright-chromium": "^1.57.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typeconv": "^2.3.1",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18.x"
  },
  "packageManager": "pnpm@10.22.0"
}
