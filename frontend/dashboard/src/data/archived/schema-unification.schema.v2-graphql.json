{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GSA-TTS/enterprise-schema-unification/schemas/contract-v2-graphql",
  "title": "Enhanced Government Contract Management Schema v2.0 with GraphQL Extensions",
  "description": "Restructured schema with definitions for compatibility with standard tooling (typeconv, core-types) and x-graphql-* extensions for automated GraphQL SDL generation",
  "x-graphql-scalars": {
    "DateTime": {
      "description": "ISO 8601 date-time string (YYYY-MM-DDTHH:mm:ss.sssZ)",
      "serialize": "String"
    },
    "Date": {
      "description": "ISO 8601 date string (YYYY-MM-DD)",
      "serialize": "String"
    },
    "Decimal": {
      "description": "High-precision decimal number for currency and financial values",
      "serialize": "Float"
    },
    "JSON": {
      "description": "Arbitrary JSON value",
      "serialize": "JSON"
    },
    "Email": {
      "description": "Valid email address",
      "serialize": "String"
    },
    "URI": {
      "description": "Valid URI/URL",
      "serialize": "String"
    }
  },
  "x-graphql-operations": {
    "queries": {
      "contract": {
        "type": "Contract",
        "description": "Fetch a single contract by global ID",
        "args": {
          "id": {
            "type": "ID!",
            "description": "Global record identifier"
          }
        }
      },
      "contractByPiid": {
        "type": "Contract",
        "description": "Fetch a contract by PIID",
        "args": {
          "piid": {
            "type": "String!",
            "description": "Procurement Instrument Identifier"
          }
        }
      },
      "contracts": {
        "type": "ContractConnection!",
        "description": "Paginated list of contracts with filtering",
        "args": {
          "first": {
            "type": "Int",
            "description": "Number of contracts to return",
            "default": 10
          },
          "after": {
            "type": "String",
            "description": "Cursor for pagination"
          },
          "filter": {
            "type": "ContractFilter",
            "description": "Filter criteria"
          },
          "orderBy": {
            "type": "ContractOrderBy",
            "description": "Ordering criteria"
          }
        }
      },
      "searchContracts": {
        "type": "[Contract!]!",
        "description": "Full-text search for contracts",
        "args": {
          "query": {
            "type": "String!",
            "description": "Search query"
          },
          "limit": {
            "type": "Int",
            "default": 20
          }
        }
      }
    },
    "mutations": {
      "triggerDataIngestion": {
        "type": "IngestionResult!",
        "description": "Trigger data ingestion from external system",
        "args": {
          "system": {
            "type": "SystemType!",
            "description": "System to ingest from (Contract Data, Legacy Procurement, Intake Process, Logistics Mgmt)"
          },
          "fullRefresh": {
            "type": "Boolean",
            "description": "Whether to perform full refresh",
            "default": false
          }
        }
      }
    }
  },
  "x-graphql-pagination": {
    "enabled": true,
    "style": "relay",
    "types": {
      "Contract": {
        "connection": "ContractConnection",
        "edge": "ContractEdge"
      }
    }
  },
  "$defs": {
    "system_type": {
      "type": "string",
      "description": "Source system type",
      "enum": ["Contract Data", "Legacy Procurement", "Intake Process", "Logistics Mgmt"],
      "x-graphql-enum": {
        "name": "SystemType",
        "description": "Federal contracting system type",
        "values": {
          "Contract Data": {
            "name": "Contract Data",
            "description": "Federal Procurement Data System - Next Generation"
          },
          "Legacy Procurement": {
            "name": "Legacy Procurement",
            "description": "Award System for Streamlined IT Transactions"
          },
          "Intake Process": {
            "name": "Intake Process",
            "description": "Enterprise Acquisition System for Infrastructure"
          },
          "Logistics Mgmt": {
            "name": "Logistics Mgmt",
            "description": "Contract Award Lifecycle Management"
          }
        }
      }
    },
    "contact_role": {
      "type": "string",
      "description": "Role classification for contract contacts",
      "enum": ["primary", "technical", "administrative", "contracting_officer"],
      "x-graphql-enum": {
        "name": "ContactRole",
        "description": "Role classification for contract personnel",
        "values": {
          "primary": {
            "name": "PRIMARY",
            "description": "Primary contact for the contract"
          },
          "technical": {
            "name": "TECHNICAL",
            "description": "Technical point of contact"
          },
          "administrative": {
            "name": "ADMINISTRATIVE",
            "description": "Administrative contact"
          },
          "contracting_officer": {
            "name": "CONTRACTING_OFFICER",
            "description": "Government contracting officer"
          }
        }
      }
    },
    "contract_status": {
      "type": "string",
      "description": "Contract lifecycle status",
      "enum": ["draft", "published", "awarded", "completed", "cancelled"],
      "x-graphql-enum": {
        "name": "ContractStatus",
        "description": "Current status in the contract lifecycle",
        "values": {
          "draft": {
            "name": "DRAFT",
            "description": "Contract in draft state"
          },
          "published": {
            "name": "PUBLISHED",
            "description": "Contract published for bidding"
          },
          "awarded": {
            "name": "AWARDED",
            "description": "Contract awarded to vendor"
          },
          "completed": {
            "name": "COMPLETED",
            "description": "Contract completed"
          },
          "cancelled": {
            "name": "CANCELLED",
            "description": "Contract cancelled"
          }
        }
      }
    },
    "data_quality": {
      "type": "object",
      "description": "Data quality metrics for system chain entry",
      "properties": {
        "completenessScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Data completeness score (0-1)"
        },
        "validationErrors": {
          "type": "array",
          "description": "List of validation errors",
          "items": {
            "type": "string"
          }
        },
        "lastValidated": {
          "type": "string",
          "format": "date-time",
          "description": "Last validation timestamp",
          "x-graphql-scalar": "DateTime"
        }
      }
    },
    "system_chain_entry": {
      "type": "object",
      "description": "Entry in the system chain showing data flow",
      "properties": {
        "systemName": {
          "$ref": "#/$defs/system_type"
        },
        "recordId": {
          "type": "string",
          "description": "Record ID in the source system"
        },
        "processedDate": {
          "type": "string",
          "format": "date-time",
          "description": "When this record was processed",
          "x-graphql-scalar": "DateTime"
        },
        "transformationRules": {
          "type": "array",
          "description": "Rules applied during transformation",
          "items": {
            "type": "string"
          }
        },
        "dataQuality": {
          "$ref": "#/$defs/data_quality"
        }
      },
      "required": ["systemName", "recordId", "processedDate"]
    },
    "system_metadata": {
      "type": "object",
      "description": "Metadata supporting multiple nested systems",
      "x-graphql-type": {
        "name": "SystemMetadata",
        "description": "System metadata tracking data lineage and quality"
      },
      "properties": {
        "primarySystem": {
          "$ref": "#/$defs/system_type",
          "description": "Primary source system"
        },
        "systemChain": {
          "type": "array",
          "description": "Chain of systems data has flowed through",
          "items": {
            "$ref": "#/$defs/system_chain_entry"
          }
        },
        "schemaVersion": {
          "type": "string",
          "default": "2.0",
          "description": "Schema version",
          "x-graphql-required": true
        },
        "lastModified": {
          "type": "string",
          "format": "date-time",
          "description": "Last modification timestamp",
          "x-graphql-scalar": "DateTime",
          "x-graphql-required": true
        },
        "globalRecordId": {
          "type": "string",
          "description": "Global unique identifier across all systems",
          "x-graphql-required": true
        }
      },
      "required": ["primarySystem", "systemChain", "globalRecordId"]
    },
    "contract_identification": {
      "type": "object",
      "description": "Contract identification information",
      "properties": {
        "piid": {
          "type": "string",
          "maxLength": 100,
          "description": "Procurement Instrument Identifier"
        },
        "originalAwardPiid": {
          "type": "string",
          "maxLength": 100,
          "description": "Original Award PIID (Preceding Reference Info)"
        },
        "referencedPiid": {
          "type": "string",
          "maxLength": 100,
          "description": "Referenced PIID for related contracts"
        },
        "contractTitle": {
          "type": "string",
          "description": "Title or description of the contract"
        },
        "contractType": {
          "type": "string",
          "description": "Type of contract instrument"
        },
        "descriptionOfRequirement": {
          "type": "string",
          "description": "Detailed description of contract requirements"
        }
      },
      "required": ["piid"]
    },
    "agency_info": {
      "type": "object",
      "description": "Agency or department information",
      "properties": {
        "code": {
          "type": "string",
          "description": "Agency or Department Code"
        },
        "name": {
          "type": "string",
          "description": "Agency or Department Name"
        }
      }
    },
    "organization_info": {
      "type": "object",
      "description": "Organization information for contracts",
      "properties": {
        "contractingAgency": {
          "allOf": [
            {
              "$ref": "#/$defs/agency_info"
            },
            {
              "required": ["code"]
            }
          ],
          "description": "Contracting agency information"
        },
        "contractingDepartment": {
          "$ref": "#/$defs/agency_info",
          "description": "Contracting department information"
        },
        "fundingAgency": {
          "$ref": "#/$defs/agency_info",
          "description": "Funding agency information"
        },
        "fundingDepartment": {
          "$ref": "#/$defs/agency_info",
          "description": "Funding department information"
        }
      },
      "required": ["contractingAgency"]
    },
    "vendor_info": {
      "type": "object",
      "description": "Vendor information",
      "properties": {
        "vendorName": {
          "type": "string",
          "description": "Name of the vendor providing goods/services"
        },
        "vendorUei": {
          "type": "string",
          "description": "Vendor Unique Entity Identifier"
        }
      }
    },
    "place_of_performance": {
      "type": "object",
      "description": "Place of performance location details",
      "properties": {
        "streetAddress": {
          "type": "string",
          "description": "Street address"
        },
        "city": {
          "type": "string",
          "description": "City"
        },
        "county": {
          "type": "string",
          "description": "County"
        },
        "state": {
          "type": "string",
          "description": "State code"
        },
        "zip": {
          "type": "string",
          "description": "ZIP code"
        },
        "country": {
          "type": "string",
          "description": "Country code"
        },
        "congressionalDistrict": {
          "type": "string",
          "description": "Congressional district"
        }
      }
    },
    "financial_info": {
      "type": "object",
      "description": "Financial information and values",
      "properties": {
        "totalContractValue": {
          "type": "number",
          "description": "Total contract value including all modifications",
          "x-graphql-scalar": "Decimal"
        },
        "baseAndAllOptionsValue": {
          "type": "number",
          "description": "Base contract value plus all option periods",
          "x-graphql-scalar": "Decimal"
        },
        "independentGovernmentEstimate": {
          "type": "number",
          "description": "IGE amount",
          "x-graphql-scalar": "Decimal"
        },
        "amountSpentOnProduct": {
          "type": "number",
          "description": "Amount spent on specific products",
          "x-graphql-scalar": "Decimal"
        },
        "contractFiscalYear": {
          "type": "string",
          "description": "Fiscal year when contract was awarded"
        }
      }
    },
    "business_classification": {
      "type": "object",
      "description": "Business classification codes and categories",
      "properties": {
        "naicsCode": {
          "type": "string",
          "description": "NAICS classification code"
        },
        "naicsDescription": {
          "type": "string",
          "description": "NAICS description"
        },
        "pscCode": {
          "type": "string",
          "description": "Product Service Code"
        },
        "pscDescription": {
          "type": "string",
          "description": "Product Service Code Description"
        },
        "categoryOfProduct": {
          "type": "string",
          "description": "General category under which the product falls"
        },
        "typeOfProduct": {
          "type": "string",
          "description": "Specific type of product being contracted"
        },
        "setAsideType": {
          "type": "string",
          "description": "Type of set-aside program"
        },
        "localAreaSetAside": {
          "type": "boolean",
          "description": "Local area set-aside flag"
        },
        "coSizeDetermination": {
          "type": "string",
          "description": "Contracting Officer size determination"
        }
      }
    },
    "contract_characteristics": {
      "type": "object",
      "description": "Contract characteristics and flags",
      "properties": {
        "emergencyAcquisition": {
          "type": "string",
          "description": "Emergency acquisition indicator"
        },
        "governmentFurnishedProperty": {
          "type": "boolean",
          "description": "Government furnished property flag"
        },
        "includesCui": {
          "type": "boolean",
          "description": "Includes Controlled Unclassified Information"
        },
        "recurringService": {
          "type": "boolean",
          "description": "Recurring service flag"
        },
        "recurringUtilities": {
          "type": "boolean",
          "description": "Recurring utilities flag"
        }
      }
    },
    "contact": {
      "type": "object",
      "description": "Contact information for contract personnel",
      "properties": {
        "name": {
          "type": "string",
          "description": "Contact name"
        },
        "title": {
          "type": "string",
          "description": "Contact title"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Contact email address",
          "x-graphql-scalar": "Email"
        },
        "phone": {
          "type": "string",
          "description": "Contact phone number"
        },
        "role": {
          "$ref": "#/$defs/contact_role"
        }
      }
    },
    "status_info": {
      "type": "object",
      "description": "Contract status information",
      "properties": {
        "isActive": {
          "type": "boolean",
          "description": "Active contract flag"
        },
        "isLatest": {
          "type": "boolean",
          "description": "Latest version flag"
        },
        "isFunded": {
          "type": "boolean",
          "description": "Funded contract flag"
        },
        "status": {
          "$ref": "#/$defs/ContractStatus"
        },
        "publishedDate": {
          "type": "string",
          "format": "date-time",
          "description": "Date contract was published",
          "x-graphql-scalar": "DateTime"
        },
        "lastModifiedDate": {
          "type": "string",
          "format": "date-time",
          "description": "Last modification date",
          "x-graphql-scalar": "DateTime"
        },
        "contractCompleteDate": {
          "type": "string",
          "format": "date",
          "description": "Date when contract was completed",
          "x-graphql-scalar": "Date"
        },
        "lastCarDateSigned": {
          "type": "string",
          "format": "date",
          "description": "Date when last Contract Action Report was signed",
          "x-graphql-scalar": "Date"
        }
      }
    },
    "CommonElements": {
      "type": "object",
      "description": "Fields common across all systems",
      "properties": {
        "contractIdentification": {
          "$ref": "#/$defs/contract_identification"
        },
        "organizationInfo": {
          "$ref": "#/$defs/organization_info"
        },
        "vendorInfo": {
          "$ref": "#/$defs/vendor_info"
        },
        "placeOfPerformance": {
          "$ref": "#/$defs/place_of_performance"
        },
        "financialInfo": {
          "$ref": "#/$defs/financial_info"
        },
        "businessClassification": {
          "$ref": "#/$defs/business_classification"
        },
        "contractCharacteristics": {
          "$ref": "#/$defs/contract_characteristics"
        },
        "contacts": {
          "type": "array",
          "description": "Contract contacts",
          "items": {
            "$ref": "#/$defs/contact"
          }
        },
        "statusInfo": {
          "$ref": "#/$defs/status_info"
        }
      },
      "required": ["contractIdentification", "organizationInfo", "statusInfo"]
    },
    "Contract DataAssistanceType": {
      "type": "object",
      "description": "Contract Data legacy_procurementance type information",
      "properties": {
        "code": {
          "type": "string",
          "description": "Assistance type code"
        },
        "value": {
          "type": "string",
          "description": "Assistance type value"
        },
        "level": {
          "type": "integer",
          "description": "Assistance level"
        }
      }
    },
    "Contract DataApplicantBeneficiaryType": {
      "type": "object",
      "description": "Contract Data applicant or beneficiary type",
      "properties": {
        "value": {
          "type": "string",
          "description": "Type value"
        },
        "code": {
          "type": "string",
          "description": "Type code"
        }
      }
    },
    "Contract DataEligibility": {
      "type": "object",
      "description": "Contract Data eligibility information",
      "properties": {
        "applicantTypes": {
          "type": "array",
          "description": "Eligible applicant types",
          "items": {
            "$ref": "#/$defs/Contract DataApplicantBeneficiaryType"
          }
        },
        "beneficiaryTypes": {
          "type": "array",
          "description": "Eligible beneficiary types",
          "items": {
            "$ref": "#/$defs/Contract DataApplicantBeneficiaryType"
          }
        },
        "additionalInfo": {
          "type": "string",
          "description": "Additional eligibility information"
        }
      }
    },
    "Contract DataUsage": {
      "type": "object",
      "description": "Contract Data usage information",
      "properties": {
        "rules": {
          "type": "string",
          "description": "Usage rules"
        },
        "restrictions": {
          "type": "string",
          "description": "Usage restrictions"
        },
        "loanTerms": {
          "type": "string",
          "description": "Loan terms"
        },
        "discretionaryFund": {
          "type": "string",
          "description": "Discretionary fund information"
        }
      }
    },
    "Contract DataSpecificData": {
      "type": "object",
      "description": "Contract Data-specific data fields",
      "properties": {
        "programNumber": {
          "type": "string",
          "description": "Contract Data program number"
        },
        "alternativeNames": {
          "type": "array",
          "description": "Alternative program names",
          "items": {
            "type": "string"
          }
        },
        "objective": {
          "type": "string",
          "description": "Program objective"
        },
        "website": {
          "type": "string",
          "format": "uri",
          "description": "Program website",
          "x-graphql-scalar": "URI"
        },
        "legacy_procurementanceTypes": {
          "type": "array",
          "description": "Assistance types",
          "items": {
            "$ref": "#/$defs/Contract DataAssistanceType"
          }
        },
        "eligibility": {
          "$ref": "#/$defs/Contract DataEligibility"
        },
        "usage": {
          "$ref": "#/$defs/Contract DataUsage"
        }
      }
    },
    "Contract DataExtension": {
      "type": "object",
      "description": "Contract Data-specific field extension",
      "properties": {
        "fieldName": {
          "type": "string",
          "description": "Field name"
        },
        "fieldType": {
          "type": "string",
          "description": "Field type"
        },
        "value": {
          "description": "Field value",
          "x-graphql-scalar": "JSON"
        },
        "contract_dataSpecific": {
          "$ref": "#/$defs/Contract DataSpecificData"
        }
      }
    },
    "AssistAcquisitionData": {
      "type": "object",
      "description": "Legacy Procurement acquisition data",
      "properties": {
        "iaPiidOrUniqueId": {
          "type": "string",
          "maxLength": 50,
          "description": "IA PIID or user-generated unique ID for the Interagency Agreement"
        },
        "natureOfAcquisition": {
          "type": "string",
          "description": "Nature of Acquisition or Relationship between GSA and Requesting Agency",
          "default": "ADMIN_CONTINUE_TRANSFER"
        }
      },
      "required": ["iaPiidOrUniqueId", "natureOfAcquisition"]
    },
    "AssistOfficeAddress": {
      "type": "object",
      "description": "Legacy Procurement office address",
      "properties": {
        "streetAddress1": {
          "type": "string",
          "description": "Street address"
        },
        "city": {
          "type": "string",
          "description": "City"
        },
        "state": {
          "type": "string",
          "description": "State"
        }
      }
    },
    "AssistClientData": {
      "type": "object",
      "description": "Legacy Procurement client data",
      "properties": {
        "clientOrganizationName": {
          "type": "string",
          "description": "Client organization name"
        },
        "officeAddress": {
          "$ref": "#/$defs/AssistOfficeAddress"
        }
      },
      "required": ["clientOrganizationName", "officeAddress"]
    },
    "AssistAwardData": {
      "type": "object",
      "description": "Legacy Procurement award data",
      "properties": {
        "typeOfIdc": {
          "type": "string",
          "description": "Type of IDC"
        },
        "whoCanUseIdc": {
          "type": "string",
          "description": "Who can use IDC"
        }
      }
    },
    "AssistSpecificData": {
      "type": "object",
      "description": "Legacy Procurement-specific data fields",
      "properties": {
        "acquisitionData": {
          "$ref": "#/$defs/AssistAcquisitionData"
        },
        "clientData": {
          "$ref": "#/$defs/AssistClientData"
        },
        "awardData": {
          "$ref": "#/$defs/AssistAwardData"
        }
      }
    },
    "AssistExtension": {
      "type": "object",
      "description": "Legacy Procurement-specific field extension",
      "properties": {
        "fieldName": {
          "type": "string",
          "description": "Field name"
        },
        "fieldType": {
          "type": "string",
          "description": "Field type"
        },
        "value": {
          "description": "Field value",
          "x-graphql-scalar": "JSON"
        },
        "legacy_procurementSpecific": {
          "$ref": "#/$defs/AssistSpecificData"
        }
      }
    },
    "EasiSpecificData": {
      "type": "object",
      "description": "EASi-specific data fields",
      "properties": {
        "businessOwner": {
          "type": "string",
          "description": "EASi Business Owner"
        },
        "systemOwner": {
          "type": "string",
          "description": "EASi System Owner"
        },
        "unitPrice": {
          "type": "number",
          "description": "Unit Price field available at the CLIN level",
          "x-graphql-scalar": "Decimal"
        },
        "unitOfMeasure": {
          "type": "string",
          "description": "Unit of Measure field available at the CLIN level"
        },
        "optional": {
          "type": "string",
          "description": "Option Period or Not Applicable"
        },
        "notToExceed": {
          "type": "string",
          "description": "Not to Exceed field"
        },
        "notSeparatelyPriced": {
          "type": "string",
          "description": "Maps to Qualifier field at CLIN level"
        }
      }
    },
    "EasiExtension": {
      "type": "object",
      "description": "EASi-specific field extension",
      "properties": {
        "fieldName": {
          "type": "string",
          "description": "Field name"
        },
        "fieldType": {
          "type": "string",
          "description": "Field type"
        },
        "value": {
