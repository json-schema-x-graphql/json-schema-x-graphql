{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GSA-TTS/enterprise-schema-unification/schemas/contract-v2-graphql",
  "title": "Enhanced Government Contract Management Schema v2.0 with GraphQL Extensions",
  "description": "Restructured schema with definitions for compatibility with standard tooling (typeconv, core-types) and x-graphql-* extensions for automated GraphQL SDL generation",
  "x-graphql-scalars": {
    "DateTime": {
      "description": "ISO 8601 date-time string (YYYY-MM-DDTHH:mm:ss.sssZ)",
      "serialize": "String"
    },
    "Date": {
      "description": "ISO 8601 date string (YYYY-MM-DD)",
      "serialize": "String"
    },
    "Decimal": {
      "description": "High-precision decimal number for currency and financial values",
      "serialize": "Float"
    },
    "JSON": {
      "description": "Arbitrary JSON value",
      "serialize": "JSON"
    },
    "Email": {
      "description": "Valid email address",
      "serialize": "String"
    },
    "URI": {
      "description": "Valid URI/URL",
      "serialize": "String"
    }
  },
  "x-graphql-operations": {
    "queries": {
      "contract": {
        "type": "Contract",
        "description": "Fetch a single contract by global ID",
        "args": {
          "id": {
            "type": "ID!",
            "description": "Global record identifier"
          }
        }
      },
      "contractByPiid": {
        "type": "Contract",
        "description": "Fetch a contract by PIID",
        "args": {
          "piid": {
            "type": "String!",
            "description": "Procurement Instrument Identifier"
          }
        }
      },
      "contracts": {
        "type": "[Contract!]!",
        "description": "List all contracts with optional filtering",
        "args": {
          "limit": {
            "type": "Int",
            "description": "Maximum number of results",
            "default": 100
          },
          "offset": {
            "type": "Int",
            "description": "Number of results to skip",
            "default": 0
          }
        }
      },
      "contractsBySystem": {
        "type": "[Contract!]!",
        "description": "List contracts by source system",
        "args": {
          "system": {
            "type": "SystemType!",
            "description": "Source system to filter by"
          }
        }
      }
    },
    "mutations": {
      "triggerDataIngestion": {
        "type": "Boolean",
        "description": "Trigger data ingestion from a source system",
        "args": {
          "system": {
            "type": "SystemType!",
            "description": "Source system to ingest from"
          },
          "batchDate": {
            "type": "String",
            "description": "Optional batch date to process"
          }
        }
      }
    }
  },
  "$defs": {
    "SystemChainEntry": {
      "type": "object",
      "description": "SystemChainEntry information",
      "properties": {
        "systemName": {
          "$ref": "#/$defs/SystemType",
          "x-graphql-required": true
        },
        "recordId": {
          "type": "string"
        },
        "processedDate": {
          "type": "string",
          "format": "date-time",
          "x-graphql-scalar": "DateTime"
        },
        "transformationRules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dataQuality": {
          "type": "object",
          "properties": {
            "completenessScore": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "validationErrors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "lastValidated": {
              "type": "string",
              "format": "date-time",
              "x-graphql-scalar": "DateTime"
            }
          }
        }
      },
      "required": ["systemName", "recordId", "processedDate"]
    },
    "DataQuality": {
      "type": "object",
      "description": "DataQuality information",
      "properties": {
        "completenessScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "validationErrors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lastValidated": {
          "type": "string",
          "format": "date-time",
          "x-graphql-scalar": "DateTime"
        }
      }
    },
    "SystemMetadata": {
      "type": "object",
      "description": "Metadata supporting multiple nested systems",
      "properties": {
        "primarySystem": {
          "$ref": "#/$defs/SystemType"
        },
        "systemChain": {
          "type": "array",
          "description": "Chain of systems data has flowed through",
          "items": {
            "$ref": "#/$defs/SystemChainEntry"
          }
        },
        "schemaVersion": {
          "type": "string",
          "default": "2.0"
        },
        "lastModified": {
          "type": "string",
          "format": "date-time",
          "x-graphql-scalar": "DateTime"
        },
        "globalRecordId": {
          "type": "string",
          "description": "Global unique identifier across all systems"
        }
      },
      "required": ["primarySystem", "systemChain", "globalRecordId"]
    },
    "ContractIdentification": {
      "type": "object",
      "description": "ContractIdentification information",
      "properties": {
        "piid": {
          "type": "string",
          "maxLength": 100,
          "description": "Procurement Instrument Identifier"
        },
        "originalAwardPiid": {
          "type": "string",
          "maxLength": 100,
          "description": "Original Award PIID (Preceding Reference Info)"
        },
        "referencedPiid": {
          "type": "string",
          "maxLength": 100,
          "description": "Referenced PIID for related contracts"
        },
        "contractTitle": {
          "type": "string",
          "description": "Title or description of the contract"
        },
        "contractType": {
          "type": "string",
          "description": "Type of contract instrument"
        },
        "descriptionOfRequirement": {
          "type": "string",
          "description": "Detailed description of contract requirements"
        }
      },
      "required": ["piid"]
    },
    "AgencyInfo": {
      "type": "object",
      "description": "Agency or department information",
      "properties": {
        "code": {
          "type": "string",
          "description": "Agency or Department Code"
        },
        "name": {
          "type": "string",
          "description": "Agency or Department Name"
        }
      }
    },
    "OrganizationInfo": {
      "type": "object",
      "properties": {
        "contractingAgency": {
          "$ref": "#/$defs/AgencyInfo"
        },
        "contractingDepartment": {
          "$ref": "#/$defs/AgencyInfo"
        },
        "fundingAgency": {
          "$ref": "#/$defs/AgencyInfo"
        },
        "fundingDepartment": {
          "$ref": "#/$defs/AgencyInfo"
        }
      },
      "required": ["contractingAgency"]
    },
    "VendorInfo": {
      "type": "object",
      "description": "VendorInfo information",
      "properties": {
        "vendorName": {
          "type": "string",
          "description": "Name of the vendor providing goods/services"
        },
        "vendorUei": {
          "type": "string",
          "description": "Vendor Unique Entity Identifier"
        }
      }
    },
    "PlaceOfPerformance": {
      "type": "object",
      "description": "PlaceOfPerformance information",
      "properties": {
        "streetAddress": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "county": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "zip": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "congressionalDistrict": {
          "type": "string"
        }
      }
    },
    "FinancialInfo": {
      "type": "object",
      "description": "FinancialInfo information",
      "properties": {
        "totalContractValue": {
          "type": "number",
          "description": "Total contract value including all modifications"
        },
        "baseAndAllOptionsValue": {
          "type": "number",
          "description": "Base contract value plus all option periods"
        },
        "independentGovernmentEstimate": {
          "type": "number",
          "description": "IGE amount"
        },
        "amountSpentOnProduct": {
          "type": "number",
          "description": "Amount spent on specific products",
          "x-graphql-scalar": "Decimal"
        },
        "contractFiscalYear": {
          "type": "string",
          "description": "Fiscal year when contract was awarded"
        }
      }
    },
    "BusinessClassification": {
      "type": "object",
      "description": "BusinessClassification information",
      "properties": {
        "naicsCode": {
          "type": "string",
          "description": "NAICS classification code"
        },
        "naicsDescription": {
          "type": "string"
        },
        "pscCode": {
          "type": "string",
          "description": "Product Service Code"
        },
        "pscDescription": {
          "type": "string",
          "description": "Product Service Code Description"
        },
        "categoryOfProduct": {
          "type": "string",
          "description": "General category under which the product falls"
        },
        "typeOfProduct": {
          "type": "string",
          "description": "Specific type of product being contracted"
        },
        "setAsideType": {
          "type": "string",
          "description": "Type of set-aside program"
        },
        "localAreaSetAside": {
          "type": "boolean"
        },
        "coSizeDetermination": {
          "type": "string",
          "description": "Contracting Officer size determination"
        }
      }
    },
    "ContractCharacteristics": {
      "type": "object",
      "description": "ContractCharacteristics information",
      "properties": {
        "emergencyAcquisition": {
          "type": "string"
        },
        "governmentFurnishedProperty": {
          "type": "boolean"
        },
        "includesCui": {
          "type": "boolean",
          "description": "Includes Controlled Unclassified Information"
        },
        "recurringService": {
          "type": "boolean"
        },
        "recurringUtilities": {
          "type": "boolean"
        }
      }
    },
    "Contact": {
      "type": "object",
      "description": "Contact information",
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email",
          "x-graphql-scalar": "Email"
        },
        "phone": {
          "type": "string"
        },
        "role": {
          "$ref": "#/$defs/ContactRole"
        }
      }
    },
    "StatusInfo": {
      "type": "object",
      "description": "StatusInfo information",
      "properties": {
        "isActive": {
          "type": "boolean"
        },
        "isLatest": {
          "type": "boolean"
        },
        "isFunded": {
          "type": "boolean"
        },
        "status": {
          "$ref": "#/$defs/ContractStatus"
        },
        "publishedDate": {
          "type": "string",
          "format": "date-time",
          "x-graphql-scalar": "DateTime"
        },
        "lastModifiedDate": {
          "type": "string",
          "format": "date-time",
          "x-graphql-scalar": "DateTime"
        },
        "contractCompleteDate": {
          "type": "string",
          "format": "date",
          "description": "Date when contract was completed",
          "x-graphql-scalar": "Date"
        },
        "lastCarDateSigned": {
          "type": "string",
          "format": "date",
          "description": "Date when last Contract Action Report was signed",
          "x-graphql-scalar": "Date"
        }
      }
    },
    "Contract DataExtension": {
      "type": "object",
      "description": "Contract Data-specific fields and extensions",
      "properties": {
        "fieldName": {
          "type": "string"
        },
        "fieldType": {
          "type": "string"
        },
        "value": {},
        "contract_dataSpecific": {
          "type": "object",
          "properties": {
            "programNumber": {
              "type": "string"
            },
            "alternativeNames": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "objective": {
              "type": "string"
            },
            "website": {
              "type": "string",
              "format": "uri",
              "x-graphql-scalar": "URI"
            },
            "legacy_procurementanceTypes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  },
                  "level": {
                    "type": "integer"
                  }
                }
              }
            },
            "eligibility": {
              "type": "object",
              "properties": {
                "applicantTypes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "value": {
                        "type": "string"
                      },
                      "code": {
                        "type": "string"
                      }
                    }
                  }
                },
                "beneficiaryTypes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "value": {
                        "type": "string"
                      },
                      "code": {
                        "type": "string"
                      }
                    }
                  }
                },
                "additionalInfo": {
                  "type": "string"
                }
              }
            },
            "usage": {
              "type": "object",
              "properties": {
                "rules": {
                  "type": "string"
                },
                "restrictions": {
                  "type": "string"
                },
                "loanTerms": {
                  "type": "string"
                },
                "discretionaryFund": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "AssistExtension": {
      "type": "object",
      "description": "Legacy Procurement-specific fields and extensions",
      "properties": {
        "fieldName": {
          "type": "string"
        },
        "fieldType": {
          "type": "string"
        },
        "value": {},
        "legacy_procurementSpecific": {
          "type": "object",
          "properties": {
            "acquisitionData": {
              "type": "object",
              "properties": {
                "iaPiidOrUniqueId": {
                  "type": "string",
                  "maxLength": 50,
                  "description": "IA PIID or user-generated unique ID for the Interagency Agreement"
                },
                "natureOfAcquisition": {
                  "type": "string",
                  "description": "Nature of Acquisition or Relationship between GSA and Requesting Agency",
                  "default": "ADMIN_CONTINUE_TRANSFER"
                }
              },
              "required": ["iaPiidOrUniqueId", "natureOfAcquisition"]
            },
            "clientData": {
              "type": "object",
              "properties": {
                "clientOrganizationName": {
                  "type": "string"
                },
                "officeAddress": {
                  "type": "object",
                  "properties": {
                    "streetAddress1": {
                      "type": "string"
                    },
                    "city": {
                      "type": "string"
                    },
                    "state": {
                      "type": "string"
                    }
                  }
                }
              },
              "required": ["clientOrganizationName", "officeAddress"]
            },
            "awardData": {
              "type": "object",
              "properties": {
                "typeOfIdc": {
                  "type": "string"
                },
                "whoCanUseIdc": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "EasiExtension": {
      "type": "object",
      "description": "EASi-specific fields and extensions",
      "properties": {
        "fieldName": {
          "type": "string"
        },
        "fieldType": {
          "type": "string"
        },
        "value": {},
        "intake_processSpecific": {
          "type": "object",
          "properties": {
            "businessOwner": {
              "type": "string",
              "description": "EASi Business Owner"
            },
            "systemOwner": {
              "type": "string",
              "description": "EASi System Owner"
            },
            "unitPrice": {
              "type": "number",
              "description": "Unit Price field available at the CLIN level"
            },
            "unitOfMeasure": {
              "type": "string",
              "description": "Unit of Measure field available at the CLIN level"
            },
            "optional": {
              "type": "string",
              "description": "Option Period or Not Applicable"
            },
            "notToExceed": {
              "type": "string",
              "description": "Not to Exceed field"
            },
            "notSeparatelyPriced": {
              "type": "string",
              "description": "Maps to Qualifier field at CLIN level"
            }
          }
        }
      }
    },
    "Contract": {
      "type": "object",
      "description": "Government contract with metadata and system-specific extensions",
      "properties": {
        "systemMetadata": {
          "$ref": "#/$defs/SystemMetadata"
        },
        "contractIdentification": {
          "$ref": "#/$defs/ContractIdentification"
        },
        "organizationInfo": {
          "$ref": "#/$defs/OrganizationInfo"
        },
        "vendorInfo": {
          "$ref": "#/$defs/VendorInfo"
        },
        "placeOfPerformance": {
          "$ref": "#/$defs/PlaceOfPerformance"
        },
        "financialInfo": {
          "$ref": "#/$defs/FinancialInfo"
        },
        "businessClassification": {
          "$ref": "#/$defs/BusinessClassification"
        },
        "contractCharacteristics": {
          "$ref": "#/$defs/ContractCharacteristics"
        },
        "contacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Contact"
          }
        },
        "statusInfo": {
          "$ref": "#/$defs/StatusInfo"
        },
        "contract_dataExtensions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Contract DataExtension"
          }
        },
        "legacy_procurementExtensions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AssistExtension"
          }
        },
        "intake_processExtensions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EasiExtension"
          }
        }
      },
      "required": ["systemMetadata", "contractIdentification", "organizationInfo", "statusInfo"]
    },
    "SystemType": {
      "type": "string",
      "enum": ["Contract Data", "Legacy Procurement", "Intake Process", "Logistics Mgmt"],
      "x-graphql-enum": {
        "name": "SystemType",
        "description": "Source system types",
        "values": {
          "Contract Data": {
            "name": "Contract Data",
            "description": "Federal Procurement Data System - Next Generation"
          },
          "Legacy Procurement": {
            "name": "Legacy Procurement",
            "description": "Award System for Streamlined IT Transactions"
          },
          "Intake Process": {
            "name": "Intake Process",
            "description": "Enterprise Acquisition System for Infrastructure"
          },
          "Logistics Mgmt": {
            "name": "Logistics Mgmt",
            "description": "Contract Award Lifecycle Management"
          }
        }
      }
    },
    "ContactRole": {
      "type": "string",
      "enum": ["primary", "technical", "administrative", "contracting_officer"],
      "x-graphql-enum": {
        "name": "ContactRole",
        "description": "Contact role types",
        "values": {
          "primary": {
            "name": "PRIMARY",
            "description": "Primary contact"
          },
          "technical": {
            "name": "TECHNICAL",
            "description": "Technical contact"
          },
          "administrative": {
            "name": "ADMINISTRATIVE",
            "description": "Administrative contact"
          },
          "contracting_officer": {
            "name": "CONTRACTING_OFFICER",
            "description": "Contracting officer"
          }
        }
      }
    },
    "ContractStatus": {
      "type": "string",
      "enum": ["draft", "published", "awarded", "completed", "cancelled"],
      "x-graphql-enum": {
        "name": "ContractStatus",
        "description": "Contract status values",
        "values": {
          "draft": {
            "name": "DRAFT",
            "description": "Draft contract"
          },
          "published": {
            "name": "PUBLISHED",
            "description": "Published contract"
          },
          "awarded": {
            "name": "AWARDED",
            "description": "Awarded contract"
          },
          "completed": {
            "name": "COMPLETED",
            "description": "Completed contract"
          },
          "cancelled": {
            "name": "CANCELLED",
            "description": "Cancelled contract"
          }
        }
      }
    },
    "SystemExtension": {
      "x-graphql-union": {
        "name": "SystemExtension",
        "description": "Union of system-specific extensions",
        "types": ["Contract DataExtension", "AssistExtension", "EasiExtension"]
      },
      "oneOf": [
        {
          "$ref": "#/$defs/Contract DataExtension"
        },
        {
          "$ref": "#/$defs/AssistExtension"
        },
        {
          "$ref": "#/$defs/EasiExtension"
        }
      ]
    }
  },
  "$ref": "#/$defs/Contract"
}
