// Prisma schema for a small POC. Points at DATABASE_URL in environment.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Solicitation {
  id                 Int     @id @default(autoincrement())
  solicitationNumber String  @map("solicitation_number")
  amendmentNumber    String? @map("amendment_number")
  title              String?
  status             String?
  amount             Float?
}

model Requisition {
  id                Int     @id @default(autoincrement())
  requisitionNumber String  @map("requisition_number")
  amendmentNumber   String? @map("amendment_number")
  description       String?
  amount            Float?
}
