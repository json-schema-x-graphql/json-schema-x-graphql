# Dockerfile for GraphQL Mesh Gateway
FROM node:20-alpine

ARG BUILD_ENV=PRODUCTION

WORKDIR /workspace

# Install build dependencies
RUN apk add --no-cache python3 make g++ ca-certificates wget

# Add the zscaler certificate to the trusted certs only on local builds
COPY .docker/zscaler_cert.pem /tmp/zscaler.crt
RUN if [ x"${BUILD_ENV}" = x"LOCAL" ] ; then cp /tmp/zscaler.crt /usr/local/share/ca-certificates/zscaler.crt ; update-ca-certificates ; fi

# Copy package files
COPY package.json ./

# Install dependencies (disable TLS verification for node-gyp during build)
RUN NODE_TLS_REJECT_UNAUTHORIZED=0 npm install --omit=dev --legacy-peer-deps

# Copy mesh configuration
COPY .meshrc.yaml ./

EXPOSE 5050

CMD ["npx", "mesh", "dev"]
